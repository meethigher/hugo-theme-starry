{{- printf "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n" | safeHTML -}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    {{- $pages := where .Site.Pages "Type" "post" }}
    {{- $pages = where $pages "Draft" "eq" false }}
    {{- $pages = where $pages "PublishDate" "<=" now }}
    {{- $pages = sort $pages "Lastmod" "desc" }}
    {{- range $pages }}
    {{- printf "\n<url>\n  <loc>%s</loc>\n  <lastmod>%s</lastmod>\n</url>" .Permalink (.Lastmod.Format "2006-01-02T15:04:05Z07:00") | safeHTML -}}
    {{- end }}
</urlset>
